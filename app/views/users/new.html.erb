<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md">
  <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">Create Your Account</h2>
  
  <%= form_with model: @user, local: true, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :full_name, "Full Name", class: "block text-gray-700 mb-2" %>
      <%= form.text_field :full_name, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div>
      <%= form.label :email, class: "block text-gray-700 mb-2" %>
      <%= form.email_field :email, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div>
      <%= form.label :password, class: "block text-gray-700 mb-2" %>
      <%= form.password_field :password, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div>
      <%= form.label :password_confirmation, "Confirm Password", class: "block text-gray-700 mb-2" %>
      <%= form.password_field :password_confirmation, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div>
      <%= form.label :date_of_birth, "Date of Birth", class: "block text-gray-700 mb-2" %>
      <%= form.date_field :date_of_birth, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div id="parent-email-field" class="hidden">
      <%= form.label :parent_email, "Parent/Guardian Email", class: "block text-gray-700 mb-2" %>
      <%= form.email_field :parent_email, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <p class="text-sm text-gray-500 mt-1">Required for users under 18 years old</p>
    </div>
    
    <div>
      <%= form.submit "Create Account", class: "w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
    </div>
  <% end %>
  
  <div class="mt-4 text-center">
    <p class="text-gray-600">Already have an account? <%= link_to "Login", login_path, class: "text-indigo-600 hover:underline" %></p>
  </div>
  
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const dobField = document.querySelector('#user_date_of_birth');
      const parentField = document.querySelector('#parent-email-field');
      
      function checkAge() {
        if (!dobField.value) return;
        
        const dob = new Date(dobField.value);
        const today = new Date();
        let age = today.getFullYear() - dob.getFullYear();
        const monthDiff = today.getMonth() - dob.getMonth();
        
        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) {
          age--;
        }
        
        if (age < 18) {
          parentField.classList.remove('hidden');
        } else {
          parentField.classList.add('hidden');
        }
      }
      
      dobField.addEventListener('change', checkAge);
      checkAge(); // Initial check
    });
  </script>
</div>
