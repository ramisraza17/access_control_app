<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md">
  <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">
    Update Role for <%= @membership.user.full_name %>
  </h2>
  
  <%= form_with model: [@organization, @membership], method: :patch, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :role, "Select Role", class: "block text-gray-700 mb-2" %>
      <%= form.select :role, 
                      options_for_select(Membership::ROLES.map { |r| [r.capitalize, r] }, @membership.role), 
                      {}, 
                      class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div>
      <%= form.submit "Update Role", class: "w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
    </div>
  <% end %>
  
  <div class="mt-4">
    <%= link_to "Back to Members", organization_memberships_path(@organization), class: "text-indigo-600 hover:underline" %>
  </div>
</div>
