<div class="max-w-4xl mx-auto">
  <div class="bg-white rounded-lg shadow-md p-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">
      Create New Space in <%= @organization.name %>
    </h1>
    
    <%= form_with model: [@organization, @space], class: "space-y-6" do |form| %>
      <div>
        <%= form.label :name, "Space Name", class: "block text-gray-700 mb-2" %>
        <%= form.text_field :name, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      
      <div>
        <%= form.label :description, class: "block text-gray-700 mb-2" %>
        <%= form.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :min_age, "Minimum Age", class: "block text-gray-700 mb-2" %>
          <%= form.number_field :min_age, min: 0, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        
        <div>
          <%= form.label :max_age, "Maximum Age", class: "block text-gray-700 mb-2" %>
          <%= form.number_field :max_age, min: 0, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
      </div>
      
      <div class="flex justify-end space-x-4 pt-6">
        <%= link_to "Cancel", organization_spaces_path(@organization), class: "bg-gray-200 hover:bg-gray-300 text-gray-800 px-4 py-2 rounded" %>
        <%= form.submit "Create Space", class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
