<div class="max-w-4xl mx-auto">
  <div class="bg-white rounded-lg shadow-md p-6">
    <div class="flex justify-between items-start mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%= @space.name %></h1>
        <p class="text-gray-600"><%= @space.organization.name %></p>
      </div>
      
      <div>
        <% if @space.age_appropriate?(current_user) %>
          <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm">
            ✓ You're a member
          </span>
        <% else %>
          <span class="bg-red-100 text-red-800 px-3 py-1 rounded-full text-sm">
            Not available for your age
          </span>
        <% end %>
      </div>
    </div>
    
    <div class="mb-6">
      <p class="text-gray-700"><%= @space.description %></p>
    </div>
    
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="bg-gray-50 p-4 rounded-lg">
        <h3 class="font-medium text-gray-700 mb-2">Age Requirements</h3>
        <p>Minimum Age: <%= @space.min_age %></p>
        <p>Maximum Age: <%= @space.max_age %></p>
      </div>
      
      <div class="bg-gray-50 p-4 rounded-lg">
        <h3 class="font-medium text-gray-700 mb-2">Your Information</h3>
        <p>Your Age: <%= current_user.age %></p>
        <p>Your Age Group: <%= current_user.age_group.to_s.capitalize %></p>
      </div>
    </div>
    
    <div class="flex space-x-4">
      <%= link_to "Back to Spaces", organization_spaces_path(@organization), 
                  class: "bg-gray-200 hover:bg-gray-300 text-gray-800 px-4 py-2 rounded" %>
    </div>
  </div>
</div>
