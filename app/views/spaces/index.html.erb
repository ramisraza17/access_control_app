<div class="max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-800">Spaces in <%= @organization.name %></h1>
    
    <% if current_membership&.has_permission?(:manage_content) %>
      <%= link_to "New Space", new_organization_space_path(@organization), 
                  class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded" %>
    <% end %>
  </div>
  
  <% if @spaces.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @spaces.each do |space| %>
        <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-200">
          <div class="p-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-2"><%= space.name %></h2>
            <p class="text-gray-600 mb-4"><%= space.description %></p>
            
            <div class="flex justify-between items-center">
              <span class="bg-<%= space.age_appropriate?(current_user) ? 'green' : 'red' %>-100 text-<%= space.age_appropriate?(current_user) ? 'green' : 'red' %>-800 text-xs font-medium px-2.5 py-0.5 rounded">
                Ages: <%= space.min_age %> - <%= space.max_age %>
              </span>
              
              <% if space.age_appropriate?(current_user) %>
                <%= button_to "Join", join_organization_space_path(@organization, space), 
                        class: "bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1 rounded text-sm" %>
              <% else %>
                <span class="text-red-500 text-sm">Not available</span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-md p-8 text-center">
      <p class="text-gray-600 mb-4">This organization doesn't have any spaces yet.</p>
      <% if current_membership&.has_permission?(:manage_content) %>
        <%= link_to "Create First Space", new_organization_space_path(@organization), 
                    class: "text-indigo-600 hover:underline" %>
      <% end %>
    </div>
  <% end %>
</div>
