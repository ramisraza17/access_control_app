<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Access Control System</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-gray-50">
  <header class="bg-indigo-600 text-white">
    <nav class="container mx-auto px-4 py-3 flex justify-between items-center">
      <%= link_to root_path, class: "text-xl font-bold" do %>
        AccessControl
      <% end %>

      <div class="flex items-center space-x-4">
        <% if current_user %>
          <span><%= current_user.full_name %></span>
          <%= link_to "Dashboard", dashboard_path, class: "hover:underline" %>
          <%= link_to "Organizations", organizations_path, class: "hover:underline" %>
          <%= button_to "Logout", logout_path, method: :delete, class: "bg-red-500 hover:bg-red-600 px-3 py-1 rounded" %>
        <% else %>
          <%= link_to "Login", login_path, class: "hover:underline" %>
          <%= link_to "Sign Up", signup_path, class: "bg-indigo-500 hover:bg-indigo-700 px-3 py-1 rounded" %>
        <% end %>
      </div>
    </nav>
  </header>

  <main class="container mx-auto px-4 py-6">
    <% if notice %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <footer class="bg-gray-800 text-white py-4 mt-8">
    <div class="container mx-auto px-4 text-center">
      &copy; <%= Time.current.year %> Access Control System
    </div>
  </footer>
</body>
</html>
