<div class="max-w-4xl mx-auto text-center py-12">
  <h1 class="text-4xl font-bold text-indigo-700 mb-6">Organization Access Control System</h1>
  <p class="text-lg text-gray-600 mb-8">Manage organizational memberships, role-based permissions, and age-based participation rules</p>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
    <div class="bg-white p-6 rounded-lg shadow-md">
      <h2 class="text-2xl font-semibold text-indigo-600 mb-4">Organization-Based Access</h2>
      <ul class="text-left list-disc pl-6 space-y-2">
        <li>Membership verification</li>
        <li>Role-based permissions</li>
        <li>Organization-specific rules</li>
        <li>Analytics & reporting</li>
      </ul>
    </div>
    
    <div class="bg-white p-6 rounded-lg shadow-md">
      <h2 class="text-2xl font-semibold text-indigo-600 mb-4">Age-Based Participation</h2>
      <ul class="text-left list-disc pl-6 space-y-2">
        <li>Age verification</li>
        <li>Age-specific spaces</li>
        <li>Content filtering</li>
        <li>Parental consent workflow</li>
      </ul>
    </div>
  </div>
  
  <div class="flex justify-center space-x-4">
    <% if current_user %>
      <%= link_to "Go to Dashboard", dashboard_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-medium" %>
    <% else %>
      <%= link_to "Get Started", signup_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-medium" %>
      <%= link_to "Learn More", "#", class: "border border-indigo-600 text-indigo-600 hover:bg-indigo-50 px-6 py-3 rounded-lg font-medium" %>
    <% end %>
  </div>
</div>
