<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md">
  <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">Login to Your Account</h2>
  
  <%= form_with url: login_path, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :email, class: "block text-gray-700 mb-2" %>
      <%= form.email_field :email, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div>
      <%= form.label :password, class: "block text-gray-700 mb-2" %>
      <%= form.password_field :password, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>
    
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <%= form.check_box :remember_me, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
        <%= form.label :remember_me, class: "ml-2 block text-sm text-gray-700" %>
      </div>
      
      <%= link_to "Forgot password?", "#", class: "text-sm text-indigo-600 hover:underline" %>
    </div>
    
    <div>
      <%= form.submit "Sign In", class: "w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
    </div>
  <% end %>
  
  <div class="mt-4 text-center">
    <p class="text-gray-600">Don't have an account? <%= link_to "Sign up", signup_path, class: "text-indigo-600 hover:underline" %></p>
  </div>
</div>
