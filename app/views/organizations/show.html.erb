<div class="max-w-6xl mx-auto">
  <div class="flex justify-between items-start mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-800"><%= @organization.name %></h1>
      <p class="text-gray-600 mt-2"><%= @organization.description %></p>
    </div>
    
    <% if @current_membership&.has_permission?(:manage_organization) %>
      <div class="space-x-2">
        <%= link_to "Edit", edit_organization_path(@organization), class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded" %>
        <%= link_to "Dashboard", dashboard_organization_path(@organization), class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded" %>
      </div>
    <% end %>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Membership</h2>
      <% if @current_membership %>
        <p class="mb-2"><span class="font-medium">Your Role:</span> <%= @current_membership.role.capitalize %></p>
        <p><span class="font-medium">Joined:</span> <%= @current_membership.created_at.strftime("%B %d, %Y") %></p>
      <% else %>
        <p class="mb-4">You are not a member of this organization</p>
        <%= button_to "Join Organization", organization_memberships_path(@organization), method: :post, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded" %>
      <% end %>
    </div>
    
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Age-Based Rules</h2>
      <% if current_user %>
        <p class="mb-2"><span class="font-medium">Your Age Group:</span> <%= current_user.age_group.to_s.capitalize %></p>
        <% rules = @organization.participation_rules[current_user.age_group.to_sym] %>
        
        <% if rules.is_a?(Hash) %>
          <ul class="list-disc pl-5">
            <% rules.each do |key, value| %>
              <li><span class="font-medium"><%= key.to_s.humanize %>:</span> <%= value %></li>
            <% end %>
          </ul>
        <% elsif rules.present? %>
          <p class="text-yellow-600">Unexpected rules format: <%= rules.inspect %></p>
        <% else %>
          <p class="text-yellow-600">No specific rules defined for your age group</p>
        <% end %>
      <% else %>
        <p>Login to see your participation rules</p>
      <% end %>
    </div>
    
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Spaces</h2>
      <p class="mb-4"><%= pluralize(@organization.spaces.count, 'space') %> available</p>
      <%= link_to "View Spaces", organization_spaces_path(@organization), class: "text-indigo-600 hover:underline" %>
    </div>
  </div>
  
  <% if @current_membership&.has_permission?(:view_analytics) %>
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Organization Analytics</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-indigo-50 p-4 rounded-lg">
          <p class="text-lg font-medium text-indigo-800"><%= @organization.users.count %></p>
          <p class="text-gray-600">Total Members</p>
        </div>
        <div class="bg-indigo-50 p-4 rounded-lg">
          <p class="text-lg font-medium text-indigo-800"><%= @organization.spaces.count %></p>
          <p class="text-gray-600">Active Spaces</p>
        </div>
        <div class="bg-indigo-50 p-4 rounded-lg">
          <p class="text-lg font-medium text-indigo-800"><%= @organization.reports.count %></p>
          <p class="text-gray-600">Reports Generated</p>
        </div>
      </div>
      <%= link_to "View Full Reports", organization_reports_path(@organization), class: "mt-4 inline-block text-indigo-600 hover:underline" %>
    </div>
  <% end %>
</div>
